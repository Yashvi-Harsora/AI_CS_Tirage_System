# ─── Required ────────────────────────────────────────────────
GEMINI_API_KEY=your_google_ai_studio_api_key_here
GEMINI_MODEL=gemini-2.5-flash

PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Optional ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
GEMINI_TIMEOUT_MS=15000
LOG_LEVEL=info
